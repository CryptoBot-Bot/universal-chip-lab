# ECU Clone Lab / Universal Chip Lab — environment template.
# Copy to ".env" and adjust for your machine. Never commit .env.

# Root folder for runtime data (jobs, dumps, logs, reports).
# Default resolves to "<repo>/.runtime" if left empty.
ECL_WORKSPACE_ROOT=

# Default operation mode. "read_only" disables every write path in the UI.
# Allowed: read_only | read_write_experimental
ECL_OPERATION_MODE=read_write_experimental

# Default adapter selected in the New Job Wizard.
# Allowed: mock_adapter | ft232h | bus_pirate | ch341a | pico | flashrom | openocd
ECL_DEFAULT_ADAPTER=mock_adapter

# Log verbosity: error | warn | info | debug | trace
ECL_LOG_LEVEL=info

# Anthropic API key for the AI chip resolver (photo → chip identification).
# Required only for the "Resolve from photo" feature. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=

# Confirm that the operator will only work on owned / authorised hardware.
# Setting this to "true" does NOT unlock any bypass features — it just stops
# the legal-use prompt from appearing on every launch.
ECL_LEGAL_USE_ACK=false
